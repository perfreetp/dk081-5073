<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.safetycampus.alarm.mapper.AlarmRecordMapper">

    <resultMap id="BaseResultMap" type="com.safetycampus.alarm.entity.AlarmRecord">
        <id column="id" property="id"/>
        <result column="alarm_no" property="alarmNo"/>
        <result column="school_id" property="schoolId"/>
        <result column="device_id" property="deviceId"/>
        <result column="alarm_type" property="alarmType"/>
        <result column="alarm_level" property="alarmLevel"/>
        <result column="alarm_title" property="alarmTitle"/>
        <result column="alarm_content" property="alarmContent"/>
        <result column="reporter_name" property="reporterName"/>
        <result column="reporter_phone" property="reporterPhone"/>
        <result column="location" property="location"/>
        <result column="longitude" property="longitude"/>
        <result column="latitude" property="latitude"/>
        <result column="parent_id" property="parentId"/>
        <result column="merged_count" property="mergedCount"/>
        <result column="status" property="status"/>
        <result column="is_escalated" property="isEscalated"/>
        <result column="escalated_at" property="escalatedAt"/>
        <result column="is_holiday" property="isHoliday"/>
        <result column="first_response_at" property="firstResponseAt"/>
        <result column="handled_at" property="handledAt"/>
        <result column="closed_at" property="closedAt"/>
        <result column="handler_id" property="handlerId"/>
        <result column="supervisor_id" property="supervisorId"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectPageByCondition" resultMap="BaseResultMap">
        SELECT a.*, s.school_name
        FROM alarm_record a
        LEFT JOIN school_info s ON a.school_id = s.id
        WHERE a.deleted = 0
        <if test="query.alarmNo != null and query.alarmNo != ''">
            AND a.alarm_no LIKE CONCAT('%', #{query.alarmNo}, '%')
        </if>
        <if test="query.schoolId != null">
            AND a.school_id = #{query.schoolId}
        </if>
        <if test="query.groupId != null">
            AND s.group_id = #{query.groupId}
        </if>
        <if test="query.alarmType != null">
            AND a.alarm_type = #{query.alarmType}
        </if>
        <if test="query.alarmLevel != null">
            AND a.alarm_level = #{query.alarmLevel}
        </if>
        <if test="query.status != null">
            AND a.status = #{query.status}
        </if>
        <if test="query.isEscalated != null">
            AND a.is_escalated = #{query.isEscalated}
        </if>
        <if test="query.isHoliday != null">
            AND a.is_holiday = #{query.isHoliday}
        </if>
        <if test="query.startTime != null">
            AND a.created_at >= #{query.startTime}
        </if>
        <if test="query.endTime != null">
            AND a.created_at <= #{query.endTime}
        </if>
        <if test="query.keyword != null and query.keyword != ''">
            AND (a.alarm_title LIKE CONCAT('%', #{query.keyword}, '%') 
                 OR a.alarm_content LIKE CONCAT('%', #{query.keyword}, '%')
                 OR s.school_name LIKE CONCAT('%', #{query.keyword}, '%'))
        </if>
        ORDER BY a.created_at DESC
    </select>

</mapper>
